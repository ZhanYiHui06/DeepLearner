---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import archives from '../../../data/challenge_archives.json';

export function getStaticPaths() {
  return archives.map(archive => ({
    params: { id: archive.id },
  }));
}

const { id } = Astro.params;
const archive = archives.find(a => a.id === id);

if (!archive) return Astro.redirect('/activities/challenge');
---

<Layout title={`${archive.title} — DeepLearner`}>
  <Navbar />
  <main class="w-full bg-black min-h-screen pt-24 pb-20" data-topics={JSON.stringify(archive.topics)}>
    <div class="max-w-4xl mx-auto px-6 lg:px-12">

      <!-- Back Link -->
      <a
        href="/activities/challenge"
        class="inline-flex items-center gap-2 font-mono text-sm text-gray-500 hover:text-white transition-colors mb-12 uppercase tracking-widest group"
      >
        <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M15 19l-7-7 7-7" />
        </svg>
        返回 人工智能挑战赛
      </a>

      <!-- Header -->
      <div class="mb-16">
        <span class="font-mono text-xs text-blue-400 uppercase tracking-widest mb-3 block">{archive.date}</span>
        <h1 class="font-display text-3xl md:text-5xl font-medium text-white tracking-tight leading-tight">
          {archive.title}
        </h1>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-3 gap-4 md:gap-6 mb-16">
        <div class="border border-white/10 bg-white/[0.02] p-6 text-center">
          <div class="font-display text-3xl md:text-5xl font-semibold text-white mb-2">{archive.stats.teams}</div>
          <div class="font-mono text-xs text-gray-400 uppercase tracking-widest">参赛队伍</div>
        </div>
        <div class="border border-white/10 bg-white/[0.02] p-6 text-center">
          <div class="font-display text-3xl md:text-5xl font-semibold text-white mb-2">{archive.stats.participants}</div>
          <div class="font-mono text-xs text-gray-400 uppercase tracking-widest">参赛人数</div>
        </div>
        <div class="border border-white/10 bg-white/[0.02] p-6 text-center">
          <div class="font-display text-3xl md:text-5xl font-semibold text-blue-400 mb-2">{archive.stats.winners}</div>
          <div class="font-mono text-xs text-gray-400 uppercase tracking-widest">获奖队伍</div>
        </div>
      </div>

      <!-- Schedule Heatmap -->
      <div class="mb-16">
        <h2 class="font-display text-xl text-white font-medium border-l-2 border-white pl-4 uppercase tracking-widest mb-8">
          赛程日历
        </h2>
        <div class="border border-white/10 bg-white/[0.02] p-6">
          <div id="heatmap" class="flex flex-wrap gap-[3px]" data-start={archive.startDate} data-end={archive.endDate} data-milestones={JSON.stringify(archive.milestones)}>
          </div>
          <!-- Legend -->
          <div class="flex items-center gap-6 mt-6 pt-4 border-t border-white/10">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-[2px] bg-white/10 border border-white/5"></div>
              <span class="text-xs text-gray-400">赛程日期</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-[2px] bg-emerald-500"></div>
              <span class="text-xs text-gray-400">重要节点</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Topics -->
      <div class="mb-16">
        <h2 class="font-display text-xl text-white font-medium border-l-2 border-white pl-4 uppercase tracking-widest mb-8">
          赛题回顾
        </h2>
        <div class="space-y-4">
          {archive.topics.map((topic, i) => (
            <button class="topic-trigger w-full flex items-center gap-4 border border-white/10 bg-white/[0.02] p-5 hover:border-white/30 hover:bg-white/[0.04] transition-all cursor-pointer text-left"
              data-index={i}>
              <span class="font-mono text-sm text-blue-400 shrink-0 w-8 text-center">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-white flex-1">{topic.title}</span>
              <svg class="w-4 h-4 text-gray-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          ))}
        </div>
      </div>

      <!-- Topic Detail Modal -->
      <div id="topic-modal" class="fixed inset-0 z-50 bg-black/95 hidden items-center justify-center p-4 md:p-12">
        <button id="topic-modal-close" class="absolute top-6 right-6 w-12 h-12 border border-white/20 flex items-center justify-center text-white hover:bg-white/10 transition-colors z-10">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        <div id="topic-modal-inner" class="max-w-2xl w-full border border-white/10 bg-[#0a0a0a] p-8 md:p-12">
          <div class="flex items-center gap-3 mb-6">
            <span id="topic-modal-num" class="font-mono text-sm text-blue-400 w-8 text-center"></span>
            <h3 id="topic-modal-title" class="font-display text-2xl md:text-3xl text-white font-medium"></h3>
          </div>
          <p id="topic-modal-desc" class="text-gray-300 font-light leading-relaxed mb-8"></p>
          <div id="topic-modal-tags" class="flex flex-wrap gap-2"></div>
        </div>
      </div>

      <!-- Poster -->
      <div class="space-y-6 mb-16">
        <h2 class="font-display text-xl text-white font-medium border-l-2 border-white pl-4 uppercase tracking-widest">
          活动海报
        </h2>
        <div class="poster-trigger border border-white/10 bg-white/[0.02] p-4 md:p-8 cursor-pointer">
          <img
            src={archive.poster}
            alt={archive.title}
            class="w-full h-auto shadow-2xl transition-transform duration-700 hover:scale-[1.01]"
          />
        </div>
      </div>

      <!-- Download PPT -->
      <div>
        <a
          href={archive.ppt}
          class="inline-flex items-center gap-4 bg-white text-black px-8 py-4 font-display font-semibold hover:bg-gray-200 transition-all group"
        >
          <span>下载活动资料</span>
          <svg class="w-5 h-5 group-hover:translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path d="M12 17V3m0 14l-4-4m4 4l4-4m5 8H3" />
          </svg>
        </a>
        <p class="text-xs text-gray-500 font-mono mt-4 uppercase tracking-widest">
          PDF / PPTX FORMAT AVAILABLE
        </p>
      </div>

    </div>
  </main>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-black/95 hidden items-center justify-center p-4 md:p-12">
    <button id="lightbox-close" class="absolute top-6 right-6 w-12 h-12 border border-white/20 flex items-center justify-center text-white hover:bg-white/10 transition-colors z-10">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <div class="lightbox-inner flex flex-col items-center">
      <img id="lightbox-img" src={archive.poster} alt={archive.title} class="max-w-[85vw] max-h-[75vh] object-contain" />
      <div class="text-center mt-8">
        <h3 id="lightbox-title" class="font-display text-xl text-white font-semibold mb-1">{archive.title}</h3>
        <p id="lightbox-date" class="font-mono text-sm text-gray-400">{archive.date}</p>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    // --- Poster Lightbox ---
    const trigger = document.querySelector('.poster-trigger') as HTMLElement;
    const lightbox = document.getElementById('lightbox') as HTMLElement;
    const lightboxInner = document.querySelector('.lightbox-inner') as HTMLElement;
    const lightboxClose = document.getElementById('lightbox-close') as HTMLElement;

    trigger?.addEventListener('click', () => {
      const rect = trigger.getBoundingClientRect();
      const originX = rect.left + rect.width / 2;
      const originY = rect.top + rect.height / 2;

      lightbox?.classList.remove('hidden');
      lightbox?.classList.add('flex');
      document.body.style.overflow = 'hidden';

      gsap.fromTo(lightbox, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' });
      gsap.fromTo(lightboxInner,
        { scale: 0.3, opacity: 0, transformOrigin: `${originX}px ${originY}px` },
        { scale: 1, opacity: 1, duration: 0.4, ease: 'power3.out' }
      );
    });

    function closeLightbox() {
      gsap.to(lightboxInner, {
        scale: 0.8,
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
      });
      gsap.to(lightbox, {
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          lightbox?.classList.add('hidden');
          lightbox?.classList.remove('flex');
          document.body.style.overflow = '';
        }
      });
    }

    lightboxClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // --- Topic Modal ---
    const topicTriggers = document.querySelectorAll('.topic-trigger') as NodeListOf<HTMLElement>;
    const topicModal = document.getElementById('topic-modal') as HTMLElement;
    const topicModalInner = document.getElementById('topic-modal-inner') as HTMLElement;
    const topicModalClose = document.getElementById('topic-modal-close') as HTMLElement;
    const topicModalNum = document.getElementById('topic-modal-num') as HTMLElement;
    const topicModalTitle = document.getElementById('topic-modal-title') as HTMLElement;
    const topicModalDesc = document.getElementById('topic-modal-desc') as HTMLElement;
    const topicModalTags = document.getElementById('topic-modal-tags') as HTMLElement;

    const topicsData = JSON.parse(topicModal.closest('[data-topics]')?.getAttribute('data-topics') || '[]');

    topicTriggers.forEach((btn) => {
      btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.index || '0');
        const topic = topicsData[i];
        if (!topic) return;

        topicModalNum.textContent = String(i + 1).padStart(2, '0');
        topicModalTitle.textContent = topic.title;
        topicModalDesc.textContent = topic.desc;
        topicModalTags.innerHTML = topic.tags.map((t: string) =>
          `<span class="font-mono text-xs text-blue-400 border border-blue-400/30 px-3 py-1 uppercase tracking-widest">${t}</span>`
        ).join('');

        const rect = btn.getBoundingClientRect();
        const originX = rect.left + rect.width / 2;
        const originY = rect.top + rect.height / 2;

        topicModal?.classList.remove('hidden');
        topicModal?.classList.add('flex');
        document.body.style.overflow = 'hidden';

        gsap.fromTo(topicModal, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' });
        gsap.fromTo(topicModalInner,
          { scale: 0.3, opacity: 0, transformOrigin: `${originX}px ${originY}px` },
          { scale: 1, opacity: 1, duration: 0.4, ease: 'power3.out' }
        );
      });
    });

    function closeTopicModal() {
      gsap.to(topicModalInner, {
        scale: 0.8,
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
      });
      gsap.to(topicModal, {
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          topicModal?.classList.add('hidden');
          topicModal?.classList.remove('flex');
          document.body.style.overflow = '';
        }
      });
    }

    topicModalClose?.addEventListener('click', closeTopicModal);
    topicModal?.addEventListener('click', (e) => {
      if (e.target === topicModal) closeTopicModal();
    });

    // --- Shared Escape handler ---
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (!topicModal?.classList.contains('hidden')) {
        closeTopicModal();
      } else if (!lightbox?.classList.contains('hidden')) {
        closeLightbox();
      }
    });

    // --- Heatmap ---
    const heatmapEl = document.getElementById('heatmap');
    if (heatmapEl) {
      const start = new Date(heatmapEl.dataset.start!);
      const end = new Date(heatmapEl.dataset.end!);
      const milestones: { label: string; date: string }[] = JSON.parse(heatmapEl.dataset.milestones || '[]');
      const milestoneMap = new Map(milestones.map(m => [m.date, m.label]));
      const firstMilestoneDate = milestones.length > 0 ? milestones[0].date : null;
      const lastMilestoneDate = milestones.length > 0 ? milestones[milestones.length - 1].date : null;

      function fireConfetti(x: number, y: number) {
        const colors = ['#34d399', '#60a5fa', '#fbbf24', '#f87171', '#a78bfa', '#ffffff'];
        const count = 40;
        for (let i = 0; i < count; i++) {
          const particle = document.createElement('div');
          const size = Math.random() * 6 + 3;
          const color = colors[Math.floor(Math.random() * colors.length)];
          const angle = Math.random() * Math.PI * 2;
          const velocity = Math.random() * 120 + 60;
          const dx = Math.cos(angle) * velocity;
          const dy = Math.sin(angle) * velocity - 80;
          const rotation = Math.random() * 720 - 360;

          Object.assign(particle.style, {
            position: 'fixed',
            left: x + 'px',
            top: y + 'px',
            width: size + 'px',
            height: size + 'px',
            backgroundColor: color,
            borderRadius: Math.random() > 0.5 ? '2px' : '50%',
            pointerEvents: 'none',
            zIndex: '100',
          });
          document.body.appendChild(particle);

          gsap.to(particle, {
            x: dx,
            y: dy,
            rotation: rotation,
            opacity: 0,
            duration: Math.random() * 0.8 + 0.6,
            ease: 'power2.out',
            onComplete: () => particle.remove(),
          });
        }
      }

      function makeCell(dateStr: string, type: 'empty' | 'active' | 'milestone') {
        const milestone = milestoneMap.get(dateStr);
        const isLastMilestone = dateStr === lastMilestoneDate;

        const cell = document.createElement('div');
        cell.className = `w-4 h-4 md:w-[18px] md:h-[18px] rounded-sm transition-all duration-150 relative group ${
          type === 'milestone' ? 'bg-emerald-500 hover:bg-emerald-400 border border-emerald-400/30 cursor-pointer' :
          type === 'active' ? 'bg-white/20 hover:bg-white/30 border border-white/15 cursor-pointer' :
          'bg-white/[0.04] hover:bg-white/[0.06] border border-white/5'
        }`;
        cell.dataset.date = dateStr;
        heatmapEl.appendChild(cell);

        // Tooltip — only for active and milestone cells
        if (type !== 'empty') {
          const tooltip = document.createElement('div');
          tooltip.className = 'absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-2 bg-[#1a1a1a] border border-white/20 rounded text-xs text-white whitespace-nowrap opacity-0 pointer-events-none transition-opacity duration-150 z-10';
          tooltip.innerHTML = milestone
            ? `<span class="text-emerald-400 font-medium">${milestone}</span><br><span class="text-gray-500 font-mono text-[10px]">${dateStr}</span>`
            : `<span class="text-gray-300">${dateStr}</span>`;
          cell.appendChild(tooltip);

          cell.addEventListener('mouseenter', () => {
            tooltip.style.opacity = '1';
            cell.style.transform = 'scale(1.15)';
            cell.style.zIndex = '10';
            if (isLastMilestone) {
              const rect = cell.getBoundingClientRect();
              fireConfetti(rect.left + rect.width / 2, rect.top);
            }
          });
          cell.addEventListener('mouseleave', () => {
            tooltip.style.opacity = '0';
            cell.style.transform = 'scale(1)';
            cell.style.zIndex = '';
          });
        }
      }

      // Render all cells
      const current = new Date(start);
      while (current <= end) {
        const dateStr = current.toISOString().slice(0, 10);
        const isMilestone = milestoneMap.has(dateStr);
        const isBetweenMilestones = firstMilestoneDate && lastMilestoneDate
          && dateStr >= firstMilestoneDate && dateStr <= lastMilestoneDate;

        const type = isMilestone ? 'milestone' : isBetweenMilestones ? 'active' : 'empty';
        makeCell(dateStr, type);
        current.setDate(current.getDate() + 1);
      }

      // Pad to complete the last row (7 cells per row)
      const totalCells = heatmapEl.children.length;
      const remainder = totalCells % 7;
      if (remainder !== 0) {
        for (let i = 0; i < 7 - remainder; i++) {
          const pad = document.createElement('div');
          pad.className = 'w-4 h-4 md:w-[18px] md:h-[18px] rounded-sm bg-white/[0.04] border border-white/5';
          heatmapEl.appendChild(pad);
        }
      }
    }
  });
</script>
