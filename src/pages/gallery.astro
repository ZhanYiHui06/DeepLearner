---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import photos from '../data/gallery.json';
---

<Layout title="影像资料 — DeepLearner">
  <Navbar />
  <main class="w-full flex-grow">

    <!-- Header -->
    <section class="w-full bg-black pt-32 pb-16 md:pt-40 md:pb-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <a href="/#gallery" class="inline-flex items-center gap-2 font-mono text-sm text-gray-400 hover:text-white transition-colors mb-8 uppercase tracking-widest">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          返回首页
        </a>
        <div class="flex flex-col items-start">
          <span class="text-white/40 font-mono tracking-[0.2em] text-sm uppercase mb-4 block">
            [ Gallery ]
          </span>
          <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold text-white tracking-tight">
            影像资料
          </h1>
          <p class="font-sans text-lg text-gray-400 font-light mt-4 max-w-2xl">
            记录 DeepLearner 的每一个重要瞬间。每一张照片背后，都是一次真实的学习与协作。
          </p>
        </div>
      </div>
    </section>

    <!-- Photo Grid -->
    <section class="w-full bg-black pb-24 md:pb-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 gsap-stagger-container">
          {photos.map((item) => (
            <div class="gallery-item relative overflow-hidden border border-white/10 cursor-pointer group gsap-stagger-item">
              <div class="aspect-[16/10] w-full overflow-hidden">
                <img 
                  src={item.img} 
                  alt={item.title} 
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <!-- Overlay on hover -->
              <div class="gallery-overlay absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
                <h3 class="gallery-overlay-title font-display font-semibold text-lg md:text-2xl text-white mb-2 leading-tight drop-shadow-lg text-shadow-md">
                  {item.title}
                </h3>
                <p class="gallery-overlay-date font-mono text-sm text-gray-400 text-shadow-sm">{item.date}</p>
              </div>
              <!-- Always-visible caption -->
              <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/70 to-transparent p-4 group-hover:opacity-0 transition-opacity duration-300">
                <h3 class="font-display font-semibold text-sm text-white truncate">{item.title}</h3>
                <p class="font-mono text-xs text-gray-500">{item.date}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Lightbox (fullscreen overlay, controlled by JS) -->
    <div id="lightbox" class="fixed inset-0 z-50 bg-black/95 hidden items-center justify-center p-4 md:p-12">
      <button id="lightbox-close" class="absolute top-6 right-6 w-12 h-12 border border-white/20 flex items-center justify-center text-white hover:bg-white/10 transition-colors z-10">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div class="lightbox-inner flex flex-col items-center">
        <img id="lightbox-img" src="" alt="" class="max-w-[85vw] max-h-[70vh] object-contain" />
        <div class="text-center mt-8">
          <h3 id="lightbox-title" class="font-display text-xl text-white font-semibold mb-1"></h3>
          <p id="lightbox-date" class="font-mono text-sm text-gray-400"></p>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    // Lightbox functionality
    const items = document.querySelectorAll('.gallery-item');
    const lightbox = document.getElementById('lightbox') as HTMLElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxTitle = document.getElementById('lightbox-title') as HTMLElement;
    const lightboxDate = document.getElementById('lightbox-date') as HTMLElement;
    const lightboxClose = document.getElementById('lightbox-close') as HTMLElement;
    const lightboxInner = document.querySelector('.lightbox-inner') as HTMLElement;

    items.forEach(item => {
      const title = item.querySelector('.gallery-overlay-title') as HTMLElement;
      const date = item.querySelector('.gallery-overlay-date') as HTMLElement;

      item.addEventListener('mouseenter', () => {
        gsap.fromTo(title,
          { scale: 0.85 },
          { scale: 1, duration: 0.4, ease: 'back.out(2)' }
        );
        gsap.fromTo(date,
          { scale: 0.85 },
          { scale: 1, duration: 0.35, delay: 0.06, ease: 'back.out(1.7)' }
        );
      });

      item.addEventListener('mouseleave', () => {
        gsap.to(title, { scale: 0.85, duration: 0.3, ease: 'back.in(2)' });
        gsap.to(date, { scale: 0.85, duration: 0.3, delay: 0.03, ease: 'back.in(1.7)' });
      });

      item.addEventListener('click', () => {
        const img = item.querySelector('img') as HTMLImageElement;
        const titleText = item.querySelector('h3')?.textContent || '';
        const dateText = item.querySelector('.font-mono')?.textContent || '';

        // Set content
        if(lightboxImg) {
          lightboxImg.src = img.src;
          lightboxImg.alt = img.alt;
        }
        if(lightboxTitle) lightboxTitle.textContent = titleText;
        if(lightboxDate) lightboxDate.textContent = dateText;

        // Get thumbnail rect for origin animation
        const rect = item.getBoundingClientRect();
        const originX = rect.left + rect.width / 2;
        const originY = rect.top + rect.height / 2;

        // Show lightbox
        lightbox?.classList.remove('hidden');
        lightbox?.classList.add('flex');
        document.body.style.overflow = 'hidden';

        // Animate from thumbnail position
        gsap.fromTo(lightbox, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' });
        gsap.fromTo(lightboxInner,
          { scale: 0.3, opacity: 0, transformOrigin: `${originX}px ${originY}px` },
          { scale: 1, opacity: 1, duration: 0.4, ease: 'power3.out' }
        );
      });
    });

    function closeLightbox() {
      gsap.to(lightboxInner, {
        scale: 0.8,
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
      });
      gsap.to(lightbox, {
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          lightbox?.classList.add('hidden');
          lightbox?.classList.remove('flex');
          document.body.style.overflow = '';
        }
      });
    }

    lightboxClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox?.classList.contains('hidden')) closeLightbox();
    });
  });
</script>
