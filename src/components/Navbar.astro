---
const links = [
  { name: '关于', href: '/#about' },
  { name: '活动', href: '/#activities' },
  { name: '影像', href: '/#gallery' },
  { name: '伙伴', href: '/#partners' },
  { name: '成果', href: '/#publications' },
  { name: '加入', href: '/#join' },
  { name: '联系', href: '/#contact' },
];
---

<header 
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300 bg-black/20 backdrop-blur-xl border-b border-white/10"
  id="navbar"
>
  <div class="max-w-7xl mx-auto px-8 md:px-12 h-16 md:h-20 flex items-center justify-between">
    <!-- Logo area -->
    <a href="/" class="flex items-center gap-3 group" aria-label="返回首页">
      <!-- Fallback styling for logo text if image is missing -->
      <div class="font-display font-semibold text-xl tracking-wider uppercase">
        <span class="sr-only">DeepLearner</span>
        <img 
          src="/images/logo_white.png" 
          alt="DeepLearner Logo" 
          class="h-6 w-auto object-contain"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
        />
        <span class="hidden group-hover:text-gray-300 transition-colors">DEEPLEARNER.</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a 
          href={link.href} 
          class="font-sans text-sm font-light text-gray-300 hover:text-white transition-colors relative group"
        >
          {link.name}
          <span class="absolute -bottom-2 left-0 w-0 h-[2px] bg-white transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <!-- Mobile Menu Toggle -->
    <button 
      id="mobile-menu-toggle" 
      class="md:hidden text-white p-2 focus:outline-none"
      aria-label="Toggle Navigation"
    >
      <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter">
        <line class="line-1" x1="4" x2="20" y1="6" y2="6"></line>
        <line class="line-2" x1="4" x2="20" y1="12" y2="12"></line>
        <line class="line-3" x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile Nav Dropdown -->
  <div 
    id="mobile-nav" 
    class="md:hidden absolute top-16 left-0 w-full bg-black/98 backdrop-blur-xl border-b border-white/5 flex flex-col items-center py-10 gap-8 -z-10 invisible pointer-events-none"
  >
    {links.map((link) => (
      <a 
        href={link.href} 
        class="font-display text-2xl font-light mobile-link text-white/70 hover:text-white transition-colors opacity-0 translate-y-4"
      >
        {link.name}
      </a>
    ))}
  </div>
</header>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const nav = document.getElementById('mobile-nav');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const menuIcon = document.getElementById('menu-icon');
    const line1 = menuIcon?.querySelector('.line-1');
    const line2 = menuIcon?.querySelector('.line-2');
    const line3 = menuIcon?.querySelector('.line-3');

    let isMenuOpen = false;

    function toggleMenu() {
      if (!nav || !menuIcon) return;
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        // Open animation
        gsap.set(nav, { autoAlpha: 1, pointerEvents: 'auto', visibility: 'visible' });
        gsap.fromTo(nav, 
          { y: '-100%', opacity: 0 }, 
          { y: '0%', opacity: 1, duration: 0.6, ease: 'power4.out', overwrite: true }
        );
        
        // Staggered links
        if (mobileLinks.length > 0) {
          gsap.to(mobileLinks, {
            y: 0,
            opacity: 1,
            duration: 0.5,
            stagger: 0.08,
            ease: 'power2.out',
            delay: 0.2
          });
        }

        // Icon animation to X
        if (line1) gsap.to(line1, { attr: { y1: 18, y2: 6 }, duration: 0.3 });
        if (line2) gsap.to(line2, { opacity: 0, duration: 0.2 });
        if (line3) gsap.to(line3, { attr: { y1: 6, y2: 18 }, duration: 0.3 });
      } else {
        // Close animation
        gsap.to(nav, { 
          y: '-100%', 
          opacity: 0, 
          duration: 0.4, 
          ease: 'power4.in',
          onComplete: () => {
            gsap.set(nav, { visibility: 'hidden', pointerEvents: 'none' });
          }
        });
        
        // Reset links position for next time
        if (mobileLinks.length > 0) {
          gsap.to(mobileLinks, { y: 16, opacity: 0, duration: 0.3 });
        }

        // Icon animation back to hamburger
        if (line1) gsap.to(line1, { attr: { y1: 6, y2: 6 }, duration: 0.3 });
        if (line2) gsap.to(line2, { opacity: 1, duration: 0.2 });
        if (line3) gsap.to(line3, { attr: { y1: 18, y2: 18 }, duration: 0.3 });
      }
    }

    toggle?.addEventListener('click', toggleMenu);

    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Optional: Add scroll styling
    const navbar = document.getElementById('navbar');
    
    function handleScroll() {
      if (window.scrollY > 50) {
        navbar?.classList.add('bg-black/50');
        navbar?.classList.remove('bg-black/20');
      } else {
        navbar?.classList.add('bg-black/20');
        navbar?.classList.remove('bg-black/50');
      }
    }

    window.addEventListener('scroll', handleScroll);

    document.addEventListener('astro:before-preparation', () => {
      window.removeEventListener('scroll', handleScroll);
    }, { once: true });
  });
</script>
