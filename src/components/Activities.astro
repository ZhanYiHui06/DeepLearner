---
import activitiesData from '../data/activities.json';
const activities = activitiesData.map(a => ({ ...a, link: `/activities/${a.slug}` }));
---

<section id="activities" class="w-full bg-black border-t-2 border-white/10 overflow-hidden">
  <div class="max-w-7xl mx-auto px-8 lg:px-12 py-24 md:py-36">
    
    <!-- Header -->
    <div class="flex flex-col items-center text-center justify-center gsap-fade-up mb-16">
      <span class="text-white/40 font-mono tracking-[0.2em] text-sm uppercase mb-4 block">
        [ 02 — Activities ]
      </span>
      <h2 class="font-display text-4xl sm:text-5xl font-semibold text-white uppercase tracking-tight">
        核心活动
      </h2>
    </div>

    <!-- Bento Grid: 1 featured + 3 smaller -->
    <div class="border border-white/10 gsap-stagger-container">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        
        <!-- Featured Card (Left, tall) -->
        <a 
          href={activities[0].link}
          class="activity-card block relative overflow-hidden lg:border-r border-white/10 gsap-stagger-item group"
        >
          <!-- Full image background -->
          <div class="aspect-[4/3] lg:aspect-auto lg:h-full w-full overflow-hidden relative">
            <div class="black-overlay absolute inset-0 bg-black/40 z-10"></div>
            <div class="absolute inset-0 bg-gray-900 flex items-center justify-center font-mono text-white/30 text-xs">IMG</div>
            <img 
              src={activities[0].image} 
              alt={activities[0].cnTitle} 
              class="card-image w-full h-full object-cover relative z-0"
              onerror="this.style.display='none';"
            />
          </div>
          <!-- Overlay content -->
          <div class="absolute inset-x-0 bottom-0 h-[50%] bg-gradient-to-t from-black/90 to-transparent flex flex-col justify-end p-8 md:p-10 z-20">
            <h3 class="card-title font-display font-semibold text-2xl md:text-3xl text-white mb-1 text-shadow-md">
              {activities[0].cnTitle}
            </h3>
            <span class="font-mono text-xs tracking-widest text-gray-400 uppercase mb-3 block">
              {activities[0].enTitle}
            </span>
            <p class="card-desc font-sans text-sm text-gray-300 font-light leading-relaxed max-w-md">
              {activities[0].desc}
            </p>
          </div>
        </a>

        <!-- Right column: 3 smaller cards stacked -->
        <div class="grid grid-cols-1">
          {activities.slice(1).map((act, index) => (
            <a 
              href={act.link}
              class="activity-card flex items-start gap-6 p-6 md:p-8 border border-white/10 -mt-px gsap-stagger-item group hover:bg-white/[0.02] transition-colors"
            >
              <!-- Thumbnail -->
              <div class="w-28 md:w-36 shrink-0 aspect-[4/3] overflow-hidden border border-white/10 relative">
                <div class="black-overlay absolute inset-0 bg-black/30 z-10"></div>
                <img 
                  src={act.image} 
                  alt={act.cnTitle} 
                  class="card-image w-full h-full object-cover"
                  onerror="this.style.display='none';"
                />
              </div>
              <!-- Text -->
              <div class="flex-1 min-w-0">
                <h3 class="card-title font-display font-semibold text-lg md:text-xl text-white mb-1 truncate">
                  {act.cnTitle}
                </h3>
                <span class="font-mono text-xs tracking-widest text-gray-500 uppercase mb-3 block">
                  {act.enTitle}
                </span>
                <p class="card-desc font-sans text-sm text-gray-400 font-light leading-relaxed line-clamp-2">
                  {act.desc}
                </p>
              </div>
              <!-- Arrow -->
              <div class="card-arrow shrink-0 w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white self-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </a>
          ))}
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll('.activity-card');

    cards.forEach(card => {
      const image = card.querySelector('.card-image');
      const overlay = card.querySelector('.black-overlay');
      const title = card.querySelector('.card-title');
      const desc = card.querySelector('.card-desc');
      const arrow = card.querySelector('.card-arrow');

      card.addEventListener('mouseenter', () => {
        gsap.to(card, { borderColor: 'rgba(255,255,255,0.3)', duration: 0.3, ease: 'power3.out' });
        if(image) gsap.to(image, { scale: 1.05, duration: 0.5, ease: 'power2.out' });
        if(overlay) gsap.to(overlay, { backgroundColor: 'transparent', duration: 0.4 });
        if(title) gsap.to(title, { color: '#60a5fa', duration: 0.3 });
        if(desc) gsap.to(desc, { color: '#d1d5db', duration: 0.3 });
        if(arrow) gsap.to(arrow, { backgroundColor: '#ffffff', color: '#000000', duration: 0.3 });
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, { borderColor: 'rgba(255,255,255,0.1)', duration: 0.3, ease: 'power3.out' });
        if(image) gsap.to(image, { scale: 1, duration: 0.5, ease: 'power2.out' });
        if(overlay) gsap.to(overlay, { backgroundColor: 'rgba(0,0,0,0.4)', duration: 0.4 });
        if(title) gsap.to(title, { color: '#ffffff', duration: 0.3 });
        if(desc) gsap.to(desc, { color: '#9ca3af', duration: 0.3 });
        if(arrow) gsap.to(arrow, { backgroundColor: 'transparent', color: '#ffffff', duration: 0.3 });
      });
    });
  });
</script>
